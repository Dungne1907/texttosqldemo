    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Run Text2SQL server",
            "program": "${workspaceFolder}/serve.js",
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome against localhost",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        }
    ],
    "compounds": [
        {
            "name": "Text2SQL full demo",
            "configurations": [
                "Run Text2SQL server",
                "Launch Chrome against localhost"
            ]
        }
    ]
}